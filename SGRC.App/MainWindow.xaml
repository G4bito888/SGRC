<Window x:Class="SGRC.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="SGRC - Sistema de Gestión de Recursos Comunitarios" 
        Height="650" Width="1050" 
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/> 
            <ColumnDefinition Width="*"/>   
        </Grid.ColumnDefinitions>

        <Border Background="{DynamicResource PrimaryHueDarkBrush}" Grid.Column="0">
            <StackPanel Margin="20">
                <TextBlock Text="SGRC" FontSize="32" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center" Margin="0,20"/>
                <Separator Background="White" Opacity="0.3" Margin="0,10"/>
                
                <Button x:Name="btnDashboard" Click="BtnDashboard_Click" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" HorizontalAlignment="Left" Margin="0,10">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ViewDashboard" Margin="0,0,10,0"/>
                        <TextBlock Text="Panel de Control"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnInventario" Click="BtnInventario_Click" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" HorizontalAlignment="Left" Margin="0,10">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Box" Margin="0,0,10,0"/> 
                        <TextBlock Text="Inventario (Oracle)"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnLogistica" Click="BtnLogistica_Click" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" HorizontalAlignment="Left" Margin="0,10">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ChartTree" Margin="0,0,10,0"/> 
                        <TextBlock Text="Logística (Neo4j)"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <ContentControl x:Name="PantallaPrincipal" Grid.Column="1"/>
    </Grid>
</Window>