<UserControl x:Class="SGRC.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Text="Bienvenid@ admin" FontSize="28" FontWeight="SemiBold" Foreground="White"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="txtReloj" Text="Cargando hora..." FontSize="22" Foreground="White" FontWeight="Medium" Margin="0,0,30,0" VerticalAlignment="Center"/>
                
                <materialDesign:Badged x:Name="badgeNotificaciones" Badge="0" Margin="0,0,10,0">
                    <ToggleButton x:Name="btnNotificaciones" Style="{StaticResource MaterialDesignIconForegroundButton}" ToolTip="Notificaciones">
                        <materialDesign:PackIcon Kind="BellRingOutline" Foreground="White" Width="28" Height="28"/>
                    </ToggleButton>
                </materialDesign:Badged>

                <Popup IsOpen="{Binding IsChecked, ElementName=btnNotificaciones}" StaysOpen="False" PlacementTarget="{Binding ElementName=btnNotificaciones}" AllowsTransparency="True" VerticalOffset="10">
                    <materialDesign:Card Padding="15" Background="White" Width="280">
                        <StackPanel>
                            <TextBlock Text="Últimas Notificaciones" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" Foreground="Black"/>
                            <ListBox x:Name="lstNotificaciones" MaxHeight="150" Foreground="DarkGray">
                                <TextBlock Text="No hay notificaciones recientes." FontStyle="Italic"/>
                            </ListBox>
                        </StackPanel>
                    </materialDesign:Card>
                </Popup>
            </StackPanel>
        </Grid>

        <UniformGrid Columns="3" Grid.Row="1">
            <materialDesign:Card Margin="10" Padding="20" Background="#f8f9fa">
                <StackPanel>
                    <materialDesign:PackIcon Kind="AlertCircle" Foreground="Red" Width="40" Height="40"/>
                    <TextBlock Text="Productos por Caducar" FontSize="18" Margin="0,10" Foreground="Black"/>
                    <TextBlock x:Name="txtItemsCriticos" Text="..." FontWeight="Bold" FontSize="24" Foreground="DarkRed"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="10" Padding="20" Background="#f8f9fa">
                <StackPanel>
                    <materialDesign:PackIcon Kind="HandHeart" Foreground="Green" Width="40" Height="40"/>
                    <TextBlock Text="Donaciones Hoy" FontSize="18" Margin="0,10" Foreground="Black"/>
                    <TextBlock x:Name="txtDonacionesHoy" Text="..." FontWeight="Bold" FontSize="24" Foreground="DarkGreen"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="10" Padding="20" Background="#f8f9fa">
                <StackPanel>
                    <materialDesign:PackIcon Kind="DatabaseCheck" Foreground="Blue" Width="40" Height="40"/>
                    <TextBlock Text="Sistemas de Datos" FontSize="18" Margin="0,10" Foreground="Black"/>
                    <TextBlock Text="Oracle &amp; Neo4j Online" FontSize="16" Foreground="Gray"/>
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <materialDesign:Card Grid.Row="2" Margin="10,20,10,10" Padding="20" Background="#f8f9fa">
            <StackPanel>
                <TextBlock Text="Registrar Nuevo Ingreso" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="Black"/>
                <UniformGrid Columns="2">
                    <TextBox x:Name="txtNombre" materialDesign:HintAssist.Hint="Nombre del Alimento" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="10"/>
                    <TextBox x:Name="txtCantidad" materialDesign:HintAssist.Hint="Cantidad (kg)" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="10"/>
                    <DatePicker x:Name="dpCaducidad" materialDesign:HintAssist.Hint="Fecha de Caducidad" Language="es-MX" Margin="10"/>
                    <TextBox x:Name="txtDonante" materialDesign:HintAssist.Hint="Nombre del Donante" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="10"/>
                </UniformGrid>
                <Button x:Name="btnRegistrar" Content="REGISTRAR INGRESO" Click="BtnRegistrar_Click" Margin="10,20,10,0" HorizontalAlignment="Right" Width="200"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>