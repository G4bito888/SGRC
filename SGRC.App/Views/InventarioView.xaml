<UserControl x:Class="SGRC.App.Views.InventarioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Inventario Actual (Oracle)" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>

        <DataGrid x:Name="gridInventario" Grid.Row="1" AutoGenerateColumns="True" 
                  IsReadOnly="True" Background="White" Foreground="Black"
                  materialDesign:DataGridAssist.CornerRadius="10"/>
    </Grid>
</UserControl>