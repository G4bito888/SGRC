<UserControl x:Class="SGRC.App.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Background="#2D2D2D">
        <materialDesign:Card Width="350" Padding="30" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="SGRC" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White" Margin="0,0,0,20"/>
                <TextBlock Text="Seleccione su rol para ingresar" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                
                <ComboBox x:Name="cbRol" materialDesign:HintAssist.Hint="Rol de Usuario" Margin="0,10">
                    <ComboBoxItem Content="Administrador"/>
                    <ComboBoxItem Content="Voluntario"/>
                </ComboBox>

                <Button x:Name="btnLogin" Content="ENTRAR AL SISTEMA" Click="BtnLogin_Click" Margin="0,20,0,0"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>